PORT=5000
NODE_ENV=production
MONGO_URI=mongodb+srv://<db_user>:<db_password>@cluster0.kfonus1.mongodb.net/ecommerce?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_super_key_2026

# Brevo SMTP Email Configuration
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM="Apex E-Commerce" <no-reply@apex-ecommerce.com>

# SSLCommerz Payment Gateway (Optional - Sandbox by default)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_IS_SANDBOX=true

# Application URLs
APP_URL=https://your-backend-app.onrender.com
FRONTEND_URL=https://your-frontend-app.vercel.app
